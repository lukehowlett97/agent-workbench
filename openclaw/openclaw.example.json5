// Stage 0 template. NVIDIA_API_KEY is read from the process environment.
{
  models: {
    providers: {
      nvidia: {
        baseUrl: "https://integrate.api.nvidia.com/v1",
        api: "openai-completions",
        timeoutSeconds: 300,
      },
    },
  },
  agents: {
    defaults: {
      model: {
        primary: "nvidia/nvidia/nemotron-3-super-120b-a12b",
        fallbacks: ["nvidia/nvidia/nemotron-3-ultra-550b-a55b"],
      },
      models: {
        "nvidia/*": {},
      },
      timeoutSeconds: 300,
      memorySearch: {
        enabled: false,
      },
    },
    list: [
      {
        id: "main",
        default: true,
        tools: { deny: ["site_publish", "site_status", "site_read", "site_rollback", "workspace_list", "workspace_read", "workspace_write", "workspace_apply_patch", "git_create_branch", "git_diff", "git_commit", "run_build", "run_tests", "create_preview", "deploy_preview", "verify_preview"] },
      },
      {
        id: "career",
        tools: { deny: ["site_publish", "site_status", "site_read", "site_rollback", "workspace_list", "workspace_read", "workspace_write", "workspace_apply_patch", "git_create_branch", "git_diff", "git_commit", "run_build", "run_tests", "create_preview", "deploy_preview", "verify_preview"] },
      },
      {
        id: "builder-agent",
        model: "nvidia/nemotron-3-super-120b-a12b",
        tools: { alsoAllow: ["site_publish", "site_status", "site_read", "site_rollback"], deny: ["exec", "process", "shell", "ssh", "read", "write", "edit", "apply_patch", "browser", "web_fetch", "web_search", "get_goal", "create_goal", "update_goal", "skill_workshop", "update_plan", "sessions_list", "sessions_history", "sessions_send", "sessions_spawn", "sessions_yield", "subagents", "session_status", "workspace_list", "workspace_read", "workspace_write", "workspace_apply_patch", "git_create_branch", "git_diff", "git_commit", "run_build", "run_tests", "create_preview", "deploy_preview", "verify_preview"] },
      },
    ],
  },
  tools: {
    profile: "minimal",
    deny: ["exec", "process", "shell", "ssh", "browser", "web_fetch", "web_search", "read", "write", "edit", "apply_patch"],
  },
  plugins: {
    entries: {
      "openclaw-builder-tools": {
        enabled: true,
        config: { serviceSecret: "${BUILDER_SERVICE_SECRET}" },
      },
    },
  },
}
