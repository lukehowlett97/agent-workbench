# Obtain from https://build.nvidia.com/settings/api-keys
# This secret is passed only to the persistent Gateway container.
NVIDIA_API_KEY=

# Stage 0 model candidates
NVIDIA_PRIMARY_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_COMPARISON_MODEL=nvidia/nemotron-3-ultra-550b-a55b
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Private web interface
WORKBENCH_USERNAME=
WORKBENCH_PASSWORD=
WORKBENCH_ENVIRONMENT=development
WORKBENCH_EXECUTOR=fixture
WORKBENCH_MODEL=nvidia/nemotron-3-super-120b-a12b

# Persistent OpenClaw Gateway
# Generate once with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_URL=ws://gateway:18789
OPENCLAW_GATEWAY_TIMEOUT_SECONDS=300
OPENCLAW_VERSION=2026.6.11
